                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Client"
                ],
                "summary": "Create a new delivery request",
                "operationId": "ce8daa161e35a9604b5761dccfb7bba2",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "item",
                                    "pickup_location",
                                    "dropoff_location"
                                ],
                                "properties": {
                                    "item": {
                                        "required": [
                                            "type"
                                        ],
                                        "properties": {
                                            "type": {
                                                "type": "string",
                                                "example": "Documento"
                                            },
                                            "weight_kg": {
                                                "type": "number",
                                                "example": 0.5
                                            },
                                            "height_cm": {
                                                "type": "number",
                                                "example": 30
                                            },
                                            "width_cm": {
                                                "type": "number",
                                                "example": 20
                                            },
                                            "length_cm": {
                                                "type": "number",
                                                "example": 5
                                            },
                                            "notes": {
                                                "type": "string",
                                                "example": "Frágil"
                                            }
                                        },
                                        "type": "object"
                                    },
                                    "pickup_location": {
                                        "required": [
                                            "latitude",
                                            "longitude"
                                        ],
                                        "properties": {
                                            "latitude": {
                                                "type": "number",
                                                "example": -23.55052
                                            },
                                            "longitude": {
                                                "type": "number",
                                                "example": -46.633308
                                            }
                                        },
                                        "type": "object"
                                    },
                                    "dropoff_location": {
                                        "required": [
                                            "latitude",
                                            "longitude"
                                        ],
                                        "properties": {
                                            "latitude": {
                                                "type": "number",
                                                "example": -23.561414
                                            },
                                            "longitude": {
                                                "type": "number",
                                                "example": -46.656166
                                            }
                                        },
                                        "type": "object"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Request created"
                    },
                    "400": {
                        "description": "Client already has active request"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
