        "/client/requests": {
            "get": {
                "tags": [
                    "Client"
                ],
                "summary": "List client's delivery requests",
                "operationId": "79d0fc5ae68a4d395046d37777557e6d",
                "responses": {
                    "200": {
                        "description": "List of requests",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "requests": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
